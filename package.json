{
    "scripts": {
        "dev": "ts-node backend/src/main.ts",
        "build": "tsc",
        "start": "node dist/main.js",
        "start:prod": "node dist/main.js",
        "prisma:generate": "prisma generate --config prisma.config.ts",
        "prisma:migrate": "prisma migrate dev --config prisma.config.ts",
        "prisma:studio": "prisma studio --config prisma.config.ts",
        "build:frontend": "npm --prefix frontend run build",
        "dev:frontend": "npm --prefix frontend run dev"
    },
    "dependencies": {
        "@nestjs/common": "^11.1.26",
        "@nestjs/core": "^11.1.26",
        "@nestjs/platform-express": "^11.1.26",
        "@nestjs/serve-static": "^5.0.5",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "dotenv": "^17.4.2",
        "pg": "^8.21.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2"
    },
    "devDependencies": {
        "@types/node": "^25.9.2",
        "@types/pg": "^8.20.0",
        "prisma": "^7.8.0",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.3"
    }
}
